    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy import constants\n",
    "\n",
    "# Set up an array of independent variables x that spans (-1e10, 1e10) m\n",
    "x = np.linspace(0, 2e10, num=201, endpoint=True) - 1e10\n",
    "\n",
    "# Make a figure\n",
    "fig, ax = plt.subplots(figsize=(7,7))\n",
    "\n",
    "# Relative velocity\n",
    "v = 0.2 * constants.c\n",
    "\n",
    "# Define the missing functions (assuming they should return arrays of the same shape as x)\n",
    "def ct_ctprimeaxis(x, v):\n",
    "    # Replace with the actual formula for ct' axis\n",
    "    gamma = 1 / np.sqrt(1 - (v/constants.c)**2)\n",
    "    return gamma * (x * v / constants.c)  # Example formula\n",
    "\n",
    "def ct_xprimeaxis(x, v):\n",
    "    # Replace with the actual formula for x' axis\n",
    "    gamma = 1 / np.sqrt(1 - (v/constants.c)**2)\n",
    "    return gamma * x  # Example formula\n",
    "\n",
    "# Compute ct values for each axis - these should now return arrays of shape (201,)\n",
    "ct_ctp = ct_ctprimeaxis(x, v)\n",
    "ct_xp = ct_xprimeaxis(x, v)\n",
    "\n",
    "# Plot the axes in red\n",
    "ax.plot(x, ct_ctp, color='red', linewidth=2)\n",
    "ax.plot(x, ct_xp, color='red', linewidth=2)\n",
    "\n",
    "# Use the same function names consistently\n",
    "ax.text(8e9, ct_ctprimeaxis(8e9, v), r\"$ct'$\", color='red')\n",
    "ax.text(8e9, ct_xprimeaxis(8e9, v), r\"$x'$\", color='red')\n",
    "\n",
    "# Move the left and bottom \"spines\" (borders of the plot) to the center\n",
    "# This makes a math textbook-like set of (x,ct) axes instead of a box around the plot\n",
    "ax.spines['left'].set_position(('data', 0))\n",
    "ax.spines['bottom'].set_position(('data', 0))\n",
    "\n",
    "# Take out the top and right spines\n",
    "ax.spines['right'].set_visible(False)\n",
    "ax.spines['top'].set_visible(False)\n",
    "\n",
    "# Make the two axes have the same scale\n",
    "ax.set_aspect('equal')\n",
    "\n",
    "# Set the axes ranges\n",
    "ax.set_xlim([-1e10, 1e10])\n",
