    "# Plot here. You may copy syntax from the previous cell.\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from scipy import constants\n",
    "\n",
    "# Set up an array of independent variables x that spans (-1e10, 1e10) m\n",
    "x = np.linspace(0, 2e10, num=201, endpoint=True) - 1e10\n",
    "\n",
    "# Make a figure\n",
    "fig, ax = plt.subplots(figsize=(7,7))\n",
    "\n",
    "c = constants.c\n",
    "velocities = [0.25*c, 0.5*c, 0.75*c]\n",
    "\n",
    "colors = ['red', 'blue', 'green']\n",
    "\n",
    "for v, color in zip(velocities, colors):\n",
    "    ct_ctp = ct_ctprimeaxis(x, v)\n",
    "    ct_xp = ct_xprimeaxis(x, v)\n",
    "\n",
    "    ax.plot(x, ct_ctp, color=color, linewidth=2,\n",
    "            label=fr\"$v = {v/c:.2f}c$\")\n",
    "    ax.plot(x, ct_xp, color=color, linewidth=2)\n",
    "\n",
    "ax.text(9.5e9, 2e8, r\"$x$ (m)\", color='black')\n",
    "ax.text(2e8, 9.5e9, r\"$ct$ (m)\", color='black')\n",
    "\n",
    "ax.legend(loc='upper left')"
   ]
